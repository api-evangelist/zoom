    "Occurrence": {
      "@id": "zoom:Occurrence",
      "@context": {
        "occurrence_id": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "start_time": {
          "@id": "schema:startDate",
          "@type": "xsd:dateTime"
        },
        "duration": {
          "@id": "schema:duration",
          "@type": "xsd:integer"
        },
        "status": {
          "@id": "schema:eventStatus",
          "@type": "xsd:string"
        }
      }
    },

    "Participant": {
      "@id": "zoom:Participant",

        },
        "file_type": {
          "@id": "schema:encodingFormat",
          "@type": "xsd:string"
        },
        "file_extension": {
          "@id": "zoom:RecordingFile/fileExtension",
          "@type": "xsd:string"
        },
        "file_size": {
          "@id": "schema:contentSize",
          "@type": "xsd:integer"
        },
        "download_url": {
          "@id": "schema:contentUrl",
          "@type": "@id"
        },
        "play_url": {
          "@id": "schema:embedUrl",
          "@type": "@id"
        },
        "status": {
          "@id": "zoom:RecordingFile/status",
          "@type": "xsd:string"
        },
        "recording_type": {
          "@id": "zoom:RecordingFile/recordingType",
          "@type": "xsd:string"
        }
      }
    },

    "LiveStream": {
      "@id": "zoom:LiveStream",
      "@context": {
        "stream_url": {

        },
        "role_in_purchase_process": {
          "@id": "zoom:Registrant/roleInPurchaseProcess",
          "@type": "xsd:string"
        },
        "custom_questions": {
          "@id": "zoom:Registrant/customQuestions",
          "@container": "@list"
        }
      }

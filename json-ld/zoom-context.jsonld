    "Poll": {
      "@id": "zoom:Poll",
      "@context": {
        "id": {
          "@id": "schema:identifier",
          "@type": "xsd:integer"
        },
        "title": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "anonymous": {
          "@id": "zoom:Poll/anonymous",
          "@type": "xsd:boolean"
        },
        "status": {
          "@id": "zoom:Poll/status",
          "@type": "xsd:string"
        },
        "poll_type": {
          "@id": "zoom:Poll/pollType",
          "@type": "xsd:integer"
        },
        "questions": {
          "@id": "zoom:Poll/questions",
          "@container": "@list"
        }
      }
    },

    "RecordingFile": {
      "@id": "zoom:RecordingFile",
      "@context": {
        "id": {
          "@id": "schema:identifier",
